generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  role      UserRole @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GameSession {
  id              String   @id @default(cuid())
  gameSlug        String
  userId          String
  playTimeMinutes Int      @default(0)
  launchCount     Int      @default(0)
  updatedAt       DateTime @updatedAt

  @@unique([gameSlug, userId])
}
